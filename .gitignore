bin/
*.tmp
/tmp/
**/.DS_Store
docs/audits/*-report.md
audits/*.log
.idea/
*.swp

# Integration-test SSH keys are generated at test time and deleted on teardown.
# NEVER commit them — this repo mirrors to public GitHub. Keep only .gitkeep.
/tests/integration/fixtures/keys/*
!/tests/integration/fixtures/keys/.gitkeep

# gate-redteam standing-target artifacts (state file, stable key dir) and
# campaign reports. Generated at runtime; never commit (the key dir holds a
# live SSH private key, the report can be large).
/.gate-redteam*
gate-redteam-report.jsonl

# Scratch/junk dir for throwaway artifacts (e.g. red-team hunt findings/ideas
# dumps, stray binaries). Never committed.
/junk/
